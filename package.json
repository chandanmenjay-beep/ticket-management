{
  "name": "ticket-management-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd apps/client && bun run build",
    "build:server": "cd apps/server && bunx prisma generate",
    "start": "bun run db:push && bun run seed && cd apps/server && bun run src/index.ts",
    "db:push": "cd apps/server && bunx prisma db push",
    "seed": "cd apps/server && bun run src/seed.ts",
    "test:e2e": "dotenv -e .env.test -- bunx playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- bunx playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "dotenv-cli": "^11.0.0",
    "pg": "^8.22.0"
  }
}
